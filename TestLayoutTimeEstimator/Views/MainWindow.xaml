<Window x:Class="TestLayoutTimeEstimator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestLayoutTimeEstimator.ViewModels"
        xmlns:conv="clr-namespace:TestLayoutTimeEstimator.Converters"
        mc:Ignorable="d"
        Title="Test Layout Time Estimator - Dashboard"
        Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="#F5F7FA"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderThickness="1"
        BorderBrush="#E0E5ED"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        Loaded="Window_Loaded">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BooleanToDoubleConverter x:Key="BooleanToDoubleConverter"/>
        <conv:IsNotNullConverter x:Key="IsNotNullConverter"/>
        <conv:BooleanToStretchConverter x:Key="BooleanToStretchConverter"/>

        <!-- Цвета дашборда -->
        <Color x:Key="PrimaryBlue">#4361EE</Color>
        <Color x:Key="PrimaryLightBlue">#4895EF</Color>
        <Color x:Key="SuccessGreen">#4CC9F0</Color>
        <Color x:Key="WarningOrange">#F8961E</Color>
        <Color x:Key="SoftPurple">#7209B7</Color>
        <Color x:Key="DarkGray">#2B2D42</Color>
        <Color x:Key="MediumGray">#4A4E69</Color>
        <Color x:Key="LightGray">#8D99AE</Color>
        <Color x:Key="OffWhite">#EDF2F4</Color>

        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="#4361EE"/>
        <SolidColorBrush x:Key="PrimaryLightBlueBrush" Color="#4895EF"/>
        <SolidColorBrush x:Key="SuccessGreenBrush" Color="#4CC9F0"/>
        <SolidColorBrush x:Key="WarningOrangeBrush" Color="#F8961E"/>
        <SolidColorBrush x:Key="SoftPurpleBrush" Color="#7209B7"/>
        <SolidColorBrush x:Key="DarkGrayBrush" Color="#2B2D42"/>
        <SolidColorBrush x:Key="MediumGrayBrush" Color="#4A4E69"/>
        <SolidColorBrush x:Key="LightGrayBrush" Color="#8D99AE"/>
        <SolidColorBrush x:Key="OffWhiteBrush" Color="#EDF2F4"/>

        <!-- Стиль для карточек дашборда -->
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E5ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1" Color="#8D99AE"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для заголовков карточек -->
        <Style x:Key="CardHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2B2D42"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- Стиль для кнопок дашборда -->
        <Style x:Key="DashboardButton" TargetType="Button">
            <Setter Property="Background" Value="#4361EE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4895EF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2B2D42"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для второстепенных кнопок -->
        <Style x:Key="SecondaryDashboardButton" TargetType="Button" BasedOn="{StaticResource DashboardButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#4361EE"/>
            <Setter Property="BorderBrush" Value="#4361EE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F7FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для метрик -->
        <Style x:Key="MetricValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2B2D42"/>
        </Style>
        <Style x:Key="MetricLabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#8D99AE"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
        <Style x:Key="PositiveChangeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4CC9F0"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>

        <!-- Стиль для текстовых полей (ModernTextBox) -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E5ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#4361EE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для списка (ModernListBox) -->
        <Style x:Key="ModernListBox" TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E5ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer Focusable="False" Padding="2">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F5F7FA" CornerRadius="18" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14.17"/>
                <RowDefinition Height="222.853"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панелька -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="📊 Dashboard" FontSize="24" FontWeight="Bold" Foreground="#2B2D42" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource SecondaryDashboardButton}" Command="{Binding SaveProjectCommand}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,8,0" FontSize="14"/>
                            <TextBlock Text="Сохранить"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryDashboardButton}" Command="{Binding LoadProjectCommand}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂" Margin="0,0,8,0" FontSize="14"/>
                            <TextBlock Text="Загрузить"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DashboardButton}" Command="{Binding NewProjectCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" Margin="0,0,8,0" FontSize="14"/>
                            <TextBlock Text="Новый проект"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Строка с метриками -->
            <Grid Grid.Row="1" Margin="0,0,0,20" Grid.RowSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Elements List Card -->
                <Border Grid.Column="2" Style="{StaticResource DashboardCard}" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📋  Список элементов" Style="{StaticResource CardHeaderText}"/>
                        <ScrollViewer>
                            <ListBox ItemsSource="{Binding CurrentProject.Elements}"
                                     SelectedItem="{Binding SelectedElement}"
                                     DisplayMemberPath="DisplayName"
                                     Height="150"
                                     Style="{StaticResource ModernListBox}"
                                     Background="White"
                                     BorderBrush="#E0E5ED"
                                     BorderThickness="1"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Project Details -->
                <Border Grid.Column="1" Style="{StaticResource DashboardCard}" Padding="20" Margin="15,0,15,0">
                    <StackPanel>
                        <TextBlock Text="📁 Детали проекта" Style="{StaticResource CardHeaderText}"/>
                        <TextBlock Text="Название проекта" Foreground="#8d99ae" FontSize="12" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding CurrentProject.Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Час за 1 балл" Foreground="#8d99ae" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding CurrentProject.HoursPerPoint, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Базовые часы" Foreground="#8d99ae" Margin="10,0,0,3"/>
                                <TextBox Text="{Binding CurrentProject.BaseHours, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" Width="120" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Complexity -->
                <Border Grid.Column="0" Style="{StaticResource DashboardCard}" Padding="20" Margin="15,0,15,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Сложность" Style="{StaticResource CardHeaderText}"/>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Март 14" Foreground="#8D99AE" FontSize="13" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding CurrentComplexityCategory.Name}" Style="{StaticResource MetricValueText}"/>
                                <TextBlock Text="Сложность" Style="{StaticResource MetricLabelText}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text=" " Foreground="#8D99AE" FontSize="13" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding ElementsCount}" Style="{StaticResource MetricValueText}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Всего элементов" Style="{StaticResource MetricLabelText}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Combined Stats Card -->
                <Border Grid.Column="3" Style="{StaticResource DashboardCard}" Padding="20" Margin="15,0,15,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="+1.69%" Style="{StaticResource PositiveChangeText}" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="0,20,0,20">
                            <TextBlock Text="{Binding DisplayTime}" Style="{StaticResource MetricValueText}" FontSize="32"/>
                            <TextBlock Text="Всего часов" Style="{StaticResource MetricLabelText}"/>
                        </StackPanel>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="0.42%" Foreground="#F8961E" FontWeight="Bold" FontSize="20"/>
                                <TextBlock Text="Сохранение" Style="{StaticResource MetricLabelText}" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding CurrentProject.BaseHours}" Foreground="#7209B7" FontWeight="Bold" FontSize="16" HorizontalAlignment="Right"/>
                                <TextBlock Text="Базовые часы" Style="{StaticResource MetricLabelText}" FontSize="12" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Основная область с канвасом -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource DashboardCard}" Padding="15" Margin="0,0,15,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="📐 Холст" FontSize="16" FontWeight="SemiBold" Foreground="#2B2D42"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource SecondaryDashboardButton}" Command="{Binding LoadImageCommand}" Padding="10,5" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🖼️" Margin="0,0,5,0"/>
                                        <TextBlock Text="Загрузить изображение"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SecondaryDashboardButton}" Command="{Binding ClearImageCommand}" Padding="10,5" Margin="0,0,10,0">
                                    <TextBlock Text="🧹 Очистить изображение"/>
                                </Button>
                                <Button Style="{StaticResource SecondaryDashboardButton}" Command="{Binding ClearAllCommand}" Padding="10,5">
                                    <TextBlock Text="🧹 Очистить все"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Канвас + изображение -->
                        <Border Grid.Row="1" BorderBrush="#E0E5ED" BorderThickness="1" CornerRadius="8" Background="White">
                            <Grid>
                                <!-- Фоновое изображение -->
                                <Image Source="{Binding CurrentProject.ImagePath}"
                                       Stretch="{Binding FitImageToCanvas, Converter={StaticResource BooleanToStretchConverter}}"
                                       HorizontalAlignment="Left" VerticalAlignment="Top"/>

                                <!-- ScrollViewer с Canvas для элементов -->
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="MainItemsControl" ItemsSource="{Binding CurrentProject.Elements}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Width="800" Height="600" Background="Transparent"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#4361EE" BorderThickness="2"
                                                        Background="#4895EF" Opacity="0.9"
                                                        Width="{Binding Width}" Height="{Binding Height}"
                                                        MouseLeftButtonDown="Border_MouseLeftButtonDown"
                                                        Cursor="Hand" CornerRadius="6">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" Background="Transparent" Margin="0"/>

                <!-- Selected Element Card -->
                <Border Grid.Column="2" Style="{StaticResource DashboardCard}" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🔹 Выбранный элемент" Style="{StaticResource CardHeaderText}"/>
                        <!-- Элементы, доступные только при выбранном элементе -->
                        <StackPanel IsEnabled="{Binding SelectedElement, Converter={StaticResource IsNotNullConverter}}">
                            <TextBlock Text="Тип элемента" Foreground="#8D99AE" FontSize="12" Margin="0,0,0,3"/>
                            <ComboBox ItemsSource="{Binding ElementTypes}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedElementType}"
                                      Margin="0,0,0,15" Padding="8,5"/>
                            <CheckBox IsChecked="{Binding SelectedElement.HasAnimation}"
                                      Content="Анимация (x1.5)" Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,10">
                                    <TextBlock Text="X" Foreground="#8D99AE" FontSize="12"/>
                                    <TextBox Text="{Binding SelectedElement.X, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,10">
                                    <TextBlock Text="Y" Foreground="#8D99AE" FontSize="12"/>
                                    <TextBox Text="{Binding SelectedElement.Y, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="Width" Foreground="#8D99AE" FontSize="12"/>
                                    <TextBox Text="{Binding SelectedElement.Width, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="Height" Foreground="#8D99AE" FontSize="12"/>
                                    <TextBox Text="{Binding SelectedElement.Height, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Кнопки Add и Remove всегда доступны (Remove зависит от команды) -->
                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource DashboardButton}"
                                    Command="{Binding AddElementCommand}" Margin="0,10,5,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="➕" Margin="0,0,5,0"/>
                                    <TextBlock Text="Добавить"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryDashboardButton}"
                                    Command="{Binding RemoveElementCommand}"
                                    IsEnabled="{Binding SelectedElement, Converter={StaticResource IsNotNullConverter}}"
                                    Margin="5,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="➖" Margin="0,0,5,0"/>
                                    <TextBlock Text="Удалить"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>